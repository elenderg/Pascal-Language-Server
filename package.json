{
	"name": "pascal-lsp",
	"displayName": "Pascal Language Server",
	"description": "Pascal Language Server powered by Free Pascal Compiler (FPC)",
	"author": "Antigravity",
	"license": "MIT",
	"version": "1.0.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/elenderg/Pascal-Language-Server"
	},
	"publisher": "antigravity",
	"categories": [
		"Programming Languages"
	],
	"keywords": [
		"pascal",
		"free pascal",
		"fpc",
		"lsp"
	],
	"engines": {
		"vscode": "^1.100.0"
	},
	"activationEvents": [
		"onLanguage:pascal"
	],
	"main": "./client/out/extension",
	"contributes": {
		"languages": [
			{
				"id": "pascal",
				"aliases": [
					"Pascal",
					"pascal"
				],
				"extensions": [
					".pas",
					".pp",
					".inc",
					".dpr",
					".lpr"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"configuration": {
			"type": "object",
			"title": "Pascal Language Server Configuration",
			"properties": {
				"pascal.compilerPath": {
					"scope": "machine-overridable",
					"type": "string",
					"default": "fpc",
					"description": "Path to the Free Pascal Compiler executable (e.g. fpc or C:\\lazarus64\\fpc\\3.2.2\\bin\\x86_64-win64\\fpc.exe)."
				},
				"pascal.compilerOptions": {
					"scope": "resource",
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Additional command line options to pass to fpc (e.g. -Fu search paths)."
				},
				"pascal.checkTrigger": {
					"scope": "resource",
					"type": "string",
					"enum": [
						"onSave",
						"onChange",
						"off"
					],
					"default": "onSave",
					"description": "When to run Free Pascal Compiler diagnostics."
				},
				"pascal.onChangeDebounceMs": {
					"scope": "resource",
					"type": "number",
					"default": 700,
					"description": "Debounce time in milliseconds before running the compiler when editing. Only applies when checkTrigger is onChange."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -b",
		"watch": "tsc -b -w",
		"lint": "eslint",
		"postinstall": "cd client && npm install && cd ../server && npm install && cd ..",
		"test": "sh ./scripts/e2e.sh"
	},
	"devDependencies": {
		"@eslint/js": "^9.13.0",
		"@stylistic/eslint-plugin": "^2.9.0",
		"@types/mocha": "^10.0.6",
		"@types/node": "^22",
		"eslint": "^9.13.0",
		"mocha": "^10.3.0",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.39.0"
	}
}